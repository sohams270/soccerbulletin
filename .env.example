# Supabase (Settings -> API in the Supabase dashboard)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Public base URL of the deployed site. Used by lib/data.ts for fetch()+tags ISR
# and by the sitemap. On Vercel set this to your production domain.
SITE_URL=http://localhost:3000

# Shared secret protecting the publish/revalidate APIs (x-api-key header).
# Leave unset in local dev to allow unauthenticated calls.
REVALIDATE_SECRET=
